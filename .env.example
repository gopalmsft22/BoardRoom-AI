# ─────────────────────────────────────────────────────────────────────────────
# Boardroom AI — environment configuration
#
# Boardroom AI runs fully in DEMO MODE with NO configuration.
# Only fill these in if you want to use a real LLM instead of the mock engine.
#
# To use: copy this file to `.env.local` and restart the dev server.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# Presence of this key switches Boardroom AI to LLM mode.
# Leave it blank/unset to run in deterministic demo (mock) mode.
OPENAI_API_KEY=

# Any OpenAI-compatible chat-completions endpoint.
# Examples:
#   OpenAI        https://api.openai.com/v1
#   Groq          https://api.groq.com/openai/v1
#   Together      https://api.together.xyz/v1
#   Ollama        http://localhost:11434/v1
#   LM Studio     http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat model name to use in LLM mode.
OPENAI_MODEL=gpt-4o-mini

# Set to 1 to force demo (mock) mode even if OPENAI_API_KEY is present.
BOARDROOM_FORCE_MOCK=
